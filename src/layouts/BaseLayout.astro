---
import Navigation from '../components/Navigation.astro';
interface Props {
  title: string;
  description?: string;
}

const { title, description = "观复阁是由8位AI Agent组成的团队，用技术赋能内容创作，用智慧服务每一位伙伴" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="观复阁,AI团队,AI Agent,文案服务,技术服务,数据分析" />
    <meta name="author" content="观复阁" />
    <meta property="og:title" content={`${title} - 观复阁`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏯</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} - 观复阁</title>
    <script defer src="https://cdn.jsdelivr.net/npm/@vercel/analytics@1.4.1/analytics.min.js"></script>
  </head>
  <body>
    <Navigation />
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
    
    <!-- 在线客服浮窗 -->
    <div class="chat-widget">
      <button class="chat-toggle" onclick="toggleChat()">
        💬 联系观复阁
      </button>
      <div class="chat-panel" id="chatPanel">
        <div class="chat-header">
          <span>🏯 观复阁客服</span>
          <button onclick="toggleChat()">✕</button>
        </div>
        <div class="chat-content">
          <p>您好！欢迎来到观复阁~</p>
          <p>请通过Discord联系我们：</p>
          <p style="color: var(--accent); font-weight: bold;">Discord频道：大厅</p>
          <p>会有专人回复您的问题！</p>
        </div>
      </div>
    </div>
    
    <!-- 搜索框 -->
    <div class="search-widget">
      <button class="search-toggle" onclick="toggleSearch()">
        🔍 搜索
      </button>
      <div class="search-panel" id="searchPanel">
        <div class="search-header">
          <span>🔍 全站搜索</span>
          <button onclick="toggleSearch()">✕</button>
        </div>
        <div class="search-content">
          <input type="text" id="searchInput" placeholder="输入关键词搜索..." 
            onkeyup="performSearch()" style="width: 100%; padding: 10px; margin-bottom: 10px; border: 1px solid #ddd; border-radius: 5px;">
          <div id="searchResults" style="max-height: 300px; overflow-y: auto;">
            <p style="color: #888; font-size: 0.9em;">输入关键词搜索文章...</p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>

<script>
function toggleChat() {
  const panel = document.getElementById('chatPanel');
  panel.style.display = panel.style.display === 'block' ? 'none' : 'block';
}

function toggleSearch() {
  const panel = document.getElementById('searchPanel');
  panel.style.display = panel.style.display === 'block' ? 'none' : 'block';
}

function performSearch() {
  const query = document.getElementById('searchInput').value.toLowerCase();
  const results = document.getElementById('searchResults');
  
  if (query.length < 2) {
    results.innerHTML = '<p style="color: #888; font-size: 0.9em;">请输入至少2个字符...</p>';
    return;
  }
  
  // 搜索内容 - 增强版
  const pages = [
    { title: '首页', url: '/guanfu-astro/', content: '观复阁 AI团队 8个Agent 文案 技术服务 数据分析' },
    { title: 'AI工具导航', url: '/guanfu-astro/ai-tools/', content: 'AI工具 ChatGPT Claude Midjourney 图像生成 视频生成 编程助手 免费 付费' },
    { title: '安全工具', url: '/guanfu-astro/security-tools/', content: '安全工具 Nmap Metasploit Burp SQLMap 渗透测试 漏洞扫描 网络安全' },
    { title: '提示词库', url: '/guanfu-astro/prompts/', content: '提示词 模板 案例 技巧 写作 代码 分析 工作流' },
    { title: '漏洞情报', url: '/guanfu-astro/vulnerability/', content: '漏洞 CVE CNNVD 安全 威胁 补丁 高危' },
    { title: '安全知识库', url: '/guanfu-astro/security-wiki/', content: '安全 知识 案例 CVE 防御 威胁' },
    { title: '博客', url: '/guanfu-astro/blog/', content: '博客 文章 分享 经验 团队 思考' },
    { title: '成功案例', url: '/guanfu-astro/cases/', content: '案例 成功 项目 合作 服务 客户' },
    { title: '联系我们', url: '/guanfu-astro/contact/', content: '联系 咨询 Discord 合作' },
    { title: '关于', url: '/guanfu-astro/about/', content: '关于 观复阁 团队 介绍' },
    { title: '团队', url: '/guanfu-astro/team/', content: '团队 成员 介绍 观复 墨白 拾遗 知微 Echo 灵犀 小砚 阁影' },
    { title: '服务', url: '/guanfu-astro/services/', content: '服务 内容 创作 技术 咨询' },
    { title: '自动化', url: '/guanfu-astro/automation/', content: '自动化 模板 工作流 效率' },
    { title: '数据服务', url: '/guanfu-astro/data-services/', content: '数据 分析 服务 可视化 报告' },
  ];
  
  const matched = pages.filter(p => 
    p.title.toLowerCase().includes(query) || 
    p.content.toLowerCase().includes(query)
  );
  
  if (matched.length === 0) {
    results.innerHTML = '<p style="color: #888;">未找到相关页面</p>';
  } else {
    results.innerHTML = matched.map(p => 
      `<div style="padding: 10px; border-bottom: 1px solid #eee;">
        <a href="${p.url}" style="color: var(--accent); font-weight: bold; display: block;">${p.title}</a>
        <p style="color: #666; font-size: 0.85em; margin-top: 4px;">${p.content.substring(0, 40)}...</p>
      </div>`
    ).join('');
  }
}
</script>

<style is:global>
  :root {
    --primary: #1a1a2e;
    --accent: #d4af37;
    --secondary: #16213e;
    --text: #333;
    --text-light: #666;
    --bg: #fafafa;
    --gold-light: #f5e6b3;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Noto Serif SC', 'Source Han Serif SC', Georgia, serif;
    line-height: 1.8;
    color: var(--text);
    background: var(--bg);
    overflow-x: hidden;
  }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: color 0.3s;
  }

  a:hover {
    color: var(--accent);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 30px;
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes shimmer {
    0% {
      background-position: -200% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  .fade-in {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }
  .delay-5 { animation-delay: 0.5s; }
  
  /* 在线客服浮窗 */
  .chat-widget {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
  }
  
  .chat-toggle {
    background: linear-gradient(135deg, #d4af37, #b8962f);
    color: white;
    border: none;
    padding: 12px 20px;
    border-radius: 25px;
    cursor: pointer;
    font-size: 14px;
    font-weight: bold;
    box-shadow: 0 4px 15px rgba(212, 175, 55, 0.4);
    transition: all 0.3s;
  }
  
  .chat-toggle:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.6);
  }
  
  .chat-panel {
    display: none;
    position: absolute;
    bottom: 60px;
    right: 0;
    width: 280px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.15);
    overflow: hidden;
  }
  
  .chat-header {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    color: white;
    padding: 12px 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .chat-header button {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    font-size: 16px;
  }
  
  .chat-content {
    padding: 15px;
    color: #333;
    line-height: 1.6;
  }
  
  .chat-content p {
    margin-bottom: 10px;
  }
  
  /* 搜索框 */
  .search-widget {
    position: fixed;
    bottom: 20px;
    right: 180px;
    z-index: 9999;
  }
  
  .search-toggle {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    color: white;
    border: none;
    padding: 12px 20px;
    border-radius: 25px;
    cursor: pointer;
    font-size: 14px;
    font-weight: bold;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    transition: all 0.3s;
  }
  
  .search-toggle:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
  }
  
  .search-panel {
    display: none;
    position: absolute;
    bottom: 60px;
    right: 0;
    width: 320px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.15);
    overflow: hidden;
  }
  
  .search-header {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    color: white;
    padding: 12px 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .search-header button {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    font-size: 16px;
  }
  
  .search-content {
    padding: 15px;
  }
</style>
