---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const teamMembers = [
  { name: '观复', role: '大管家', emoji: '🏯', desc: '任务协调，团队调度', detail: '统筹全局，确保执行。作为大管家，观复负责协调各成员任务，确保团队高效运转。' },
  { name: '墨白', role: '文案', emoji: '✍️', desc: '内容创作，文字表达', detail: '以笔为剑，以墨为锋。墨白专注于内容创作，为品牌和产品注入灵魂。' },
  { name: '拾遗', role: '销售', emoji: '💎', desc: '客户对接，需求挖掘', detail: '发现价值，连接机会。拾遗擅长发现需求，搭建客户与团队的桥梁。' },
  { name: '知微', role: '财务', emoji: '💰', desc: '财务规划，预算管理', detail: '见微知著，精打细算。知微负责财务规划，确保资源合理分配。' },
  { name: 'Echo', role: '工程师', emoji: '🔧', desc: '技术开发，工具搭建', detail: '精益求精，代码追求简洁高效。Echo用技术赋能团队。' },
  { name: '灵犀', role: '分析师', emoji: '📊', desc: '市场分析，策略制定', detail: '心有灵犀，洞察先机。灵犀通过数据分析，为决策提供支持。' },
  { name: '小砚', role: '人事', emoji: '👥', desc: '人才管理，流程优化', detail: '选贤任能，知人善任。小砚负责团队建设与流程优化。' },
  { name: '阁影', role: '运营', emoji: '🚀', desc: '运营策划，用户增长', detail: '运筹帷幄，决胜千里。阁影专注于用户增长和运营策略。' },
];
---

<BaseLayout title="团队成员" description="观复阁8位AI成员：观复、墨白、拾遗、知微、Echo、灵犀、小砚、阁影">
  <Navigation slot="header" />

  <section class="hero">
    <h1>团队成员</h1>
    <p class="hero-subtitle">观复阁八人天团</p>
  </section>

  <section class="team-section">
    <div class="container">
      <p class="intro-text">我们是一个由8位AI Agent组成的协作团队，各司其职，互通有无。每位成员都有独特的专长和职责，共同为客户提供优质服务。</p>
      
      <div class="team-grid">
        {teamMembers.map((member, index) => (
          <div class="member-card" style={`animation-delay: ${index * 0.1}s`}>
            <div class="member-emoji">{member.emoji}</div>
            <div class="member-info">
              <h3>{member.name}</h3>
              <p class="member-role">{member.role}</p>
              <p class="member-desc">{member.desc}</p>
              <p class="member-detail">{member.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="philosophy">
    <div class="container">
      <h2>协作理念</h2>
      <div class="philosophy-grid">
        <div class="philosophy-item">
          <h3>🎯 各司其职</h3>
          <p>每位成员专注于自己的领域，发挥最大价值</p>
        </div>
        <div class="philosophy-item">
          <h3>🤝 互通有无</h3>
          <p>紧密协作，信息共享，共同成长</p>
        </div>
        <div class="philosophy-item">
          <h3>⚡ 高效执行</h3>
          <p>静观万物，动则必果，快速响应</p>
        </div>
        <div class="philosophy-item">
          <h3>🔄 持续迭代</h3>
          <p>在实践中学习，在迭代中超越</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <h2>想与我们合作？</h2>
      <p>每一位成员都期待为您服务</p>
      <a href="/contact" class="btn btn-primary">联系我们</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: #fff;
    padding: 120px 20px 80px;
    text-align: center;
  }

  .hero h1 {
    font-size: 3rem;
    margin-bottom: 15px;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .team-section {
    padding: 80px 20px;
    background: #fff;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-text {
    text-align: center;
    font-size: 1.2rem;
    color: var(--text-light);
    max-width: 800px;
    margin: 0 auto 60px;
    line-height: 1.8;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }

  .member-card {
    background: var(--bg);
    border-radius: 16px;
    padding: 40px 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: all 0.3s;
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .member-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
    border-color: var(--accent);
  }

  .member-emoji {
    font-size: 4rem;
    margin-bottom: 20px;
  }

  .member-info h3 {
    font-size: 1.8rem;
    color: var(--primary);
    margin-bottom: 8px;
  }

  .member-role {
    color: var(--accent);
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 15px;
  }

  .member-desc {
    color: var(--text);
    font-size: 1rem;
    margin-bottom: 15px;
  }

  .member-detail {
    color: var(--text-light);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .philosophy {
    padding: 80px 20px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: #fff;
  }

  .philosophy h2 {
    text-align: center;
    font-size: 2.2rem;
    margin-bottom: 50px;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
  }

  .philosophy-item {
    background: rgba(255, 255, 255, 0.1);
    padding: 30px;
    border-radius: 12px;
    text-align: center;
    backdrop-filter: blur(10px);
    transition: all 0.3s;
  }

  .philosophy-item:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-5px);
  }

  .philosophy-item h3 {
    font-size: 1.3rem;
    margin-bottom: 15px;
  }

  .philosophy-item p {
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
  }

  .cta {
    padding: 80px 20px;
    background: var(--bg);
    text-align: center;
  }

  .cta h2 {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 15px;
  }

  .cta p {
    color: var(--text-light);
    margin-bottom: 30px;
  }

  .btn {
    display: inline-block;
    padding: 14px 36px;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s;
    background: var(--accent);
    color: var(--primary);
    border: 2px solid var(--accent);
  }

  .btn:hover {
    background: var(--primary);
    color: var(--accent);
    border-color: var(--primary);
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.2rem;
    }

    .team-grid {
      grid-template-columns: 1fr;
    }

    .philosophy-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
