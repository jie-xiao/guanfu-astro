<style>
  .hero {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  }
  .hero h1 {
    font-size: 2.5rem;
    color: #d4af37;
    margin-bottom: 1rem;
  }
  .hero p {
    color: rgba(255,255,255,0.8);
    font-size: 1.1rem;
  }
  .content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  .tools-section {
    margin-bottom: 3rem;
  }
  .tools-section h2 {
    color: #d4af37;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(212, 175, 55, 0.3);
  }
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  .tool-card {
    background: rgba(26, 26, 46, 0.5);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s;
  }
  .tool-card:hover {
    transform: translateY(-5px);
    border-color: #d4af37;
    box-shadow: 0 5px 20px rgba(212, 175, 55, 0.2);
  }
  .tool-card h3 {
    color: #d4af37;
    margin-bottom: 0.5rem;
  }
  .tool-card p {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .tag {
    display: inline-block;
    background: rgba(212, 175, 55, 0.2);
    color: #d4af37;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.8rem;
  }

  .link {
    display: inline-block;
    margin-left: 0.5rem;
    color: #4a9eff;
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.3s;
  }

  .link:hover {
    color: #70b8ff;
  }

  .tag-free {
    display: inline-block;
    background: rgba(76, 175, 80, 0.2);
    color: #4caf50;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    margin-left: 0.3rem;
  }

  .场景 {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
  }
</style>
