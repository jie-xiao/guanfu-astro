---
import BaseLayout from '../layouts/BaseLayout.astro';

// 获取所有博客文章
const blogFiles = import.meta.glob('./blog/*.astro', { eager: true });

const blogs = Object.entries(blogFiles).map(([path, module]) => {
  // 从文件路径提取文件名
  const filename = path.split('/').pop().replace('.astro', '');
  
  // 尝试从 module.default 中提取信息
  // 由于 Astro 组件的结构，我们需要解析 HTML 内容
  return {
    slug: filename,
    // 默认值，实际解析需要在组件渲染时进行
    title: filename,
    date: '2026-01-01',
    author: '未知',
    excerpt: '点击查看详情...'
  };
});

// 由于 Astro.glob 返回的是组件对象，我们用另一种方式
// 读取所有博客文件内容来解析元数据
const fs = await import('fs');
const path = await import('path');
const blogDir = './src/pages/blog';
const files = fs.readdirSync(blogDir).filter(f => f.endsWith('.astro'));

const blogs2 = files.map(filename => {
  const slug = filename.replace('.astro', '');
  const content = fs.readFileSync(path.join(blogDir, filename), 'utf-8');
  
  // 提取日期
  const dateMatch = content.match(/post-date[^>]*>(\d{4}-\d{2}-\d{2})/);
  const date = dateMatch ? dateMatch[1] : '2026-01-01';
  
  // 提取作者
  const authorMatch = content.match(/post-author[^>]*>([^<]+)/);
  const author = authorMatch ? authorMatch[1] : '未知';
  
  // 提取标题
  const titleMatch = content.match(/<h1>([^<]+)<\/h1>/);
  const title = titleMatch ? titleMatch[1] : slug;
  
  // 提取摘要
  const excerptMatch = content.match(/<p>([^<]{50,150})/);
  const excerpt = excerptMatch ? excerptMatch[1] + '...' : '点击查看详情...';
  
  return { slug, date, author, title, excerpt };
});

// 按日期排序
blogs2.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="博客 - 观复阁" description="观复阁博客 - 团队思考与分享">
  <section class="hero">
    <div class="container">
      <h1>📝 博客</h1>
      <p>团队思考与分享</p>
      <p style="margin-top:1rem;opacity:0.7">共 {blogs2.length} 篇文章</p>
    </div>
  </section>

  <section class="content">
    <div class="container">
      
      <div class="blog-list">
        {blogs2.map(blog => (
          <article class="blog-card">
            <div class="blog-meta">
              <span class="blog-date">{blog.date}</span>
              <span class="blog-author">{blog.author}</span>
            </div>
            <h2>{blog.title}</h2>
            <p class="blog-excerpt">
              {blog.excerpt}
            </p>
            <a href={`/blog/${blog.slug}`} class="read-more">阅读全文 →</a>
          </article>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 20px;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
  }

  .hero h1 {
    color: #d4af37;
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .content {
    padding: 40px 0;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .blog-card {
    background: #fff;
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: all 0.3s;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
  }

  .blog-meta {
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 10px;
  }

  .blog-author {
    color: #d4af37;
    margin-left: 15px;
  }

  .blog-card h2 {
    color: #1a1a2e;
    font-size: 1.5rem;
    margin-bottom: 15px;
  }

  .blog-excerpt {
    color: #666;
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .read-more {
    display: inline-block;
    color: #d4af37;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s;
  }

  .read-more:hover {
    color: #b8962f;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 2rem;
    }
    
    .blog-card {
      padding: 20px;
    }
  }
</style>
