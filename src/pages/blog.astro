<style>
  .hero {
    text-align: center;
    padding: 4rem 20px;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
  }

  .hero h1 {
    color: #d4af37;
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .content {
    padding: 40px 0;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .blog-card {
    background: #fff;
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: all 0.3s;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
  }

  .blog-meta {
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 10px;
  }

  .blog-author {
    color: #d4af37;
    margin-left: 15px;
  }

  .blog-card h2 {
    color: #1a1a2e;
    font-size: 1.5rem;
    margin-bottom: 15px;
  }

  .blog-excerpt {
    color: #666;
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .read-more {
    display: inline-block;
    color: #d4af37;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s;
  }

  .read-more:hover {
    color: #b8962f;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 2rem;
    }
    
    .blog-card {
      padding: 20px;
    }
  }
</style>
