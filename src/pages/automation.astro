---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="自动化模板 - 观复阁" description="观复阁自动化模板 - 工作流模板、效率工具、自动化方案">
  <section class="hero">
    <div class="container">
      <h1>📢 自动化模板</h1>
      <p>工作流模板 · 效率工具 · 自动化方案</p>
    </div>
  </section>

  <section class="content">
    <div class="container">
      
      <!-- 自动化工具 -->
      <section class="tool-section">
        <h2>🛠️ 自动化工具</h2>
        
        <div class="tool-card">
          <h3>📝 内容创作自动化</h3>
          <p>AI辅助内容创作工作流，提升写作效率。</p>
          <ul>
            <li>选题自动生成</li>
            <li>大纲自动规划</li>
            <li>初稿自动生成</li>
            <li>多平台一键分发</li>
          </ul>
        </div>

        <div class="tool-card">
          <h3>📊 数据分析自动化</h3>
          <p>自动化数据收集、清洗、分析流程。</p>
          <ul>
            <li>数据自动采集</li>
            <li>报表自动生成</li>
            <li>趋势自动分析</li>
            <li>异常自动预警</li>
          </ul>
        </div>

        <div class="tool-card">
          <h3>🔄 运维自动化</h3>
          <p>DevOps流程自动化，提高运维效率。</p>
          <ul>
            <li>CI/CD流水线</li>
            <li>自动部署</li>
            <li>监控告警</li>
            <li>日志分析</li>
          </ul>
        </div>

        <div class="tool-card">
          <h3>💬 客服自动化</h3>
          <p>智能客服工作流，提升响应效率。</p>
          <ul>
            <li>自动回复</li>
            <li>智能分流</li>
            <li>工单自动创建</li>
            <li>满意度调查</li>
          </ul>
        </div>
      </section>

      <!-- 模板下载 -->
      <section class="template-section">
        <h2>📥 模板中心</h2>
        
        <div class="template-grid">
          <div class="template-card">
            <div class="template-icon">📝</div>
            <h3>内容创作模板</h3>
            <p>博客文章、工作报告、营销文案模板</p>
            <span class="template-tag">写作</span>
          </div>

          <div class="template-card">
            <div class="template-icon">📊</div>
            <h3>数据分析模板</h3>
            <p>Excel模板、报表模板、仪表盘模板</p>
            <span class="template-tag">数据</span>
          </div>

          <div class="template-card">
            <div class="template-icon">🔄</div>
            <h3>运维脚本模板</h3>
            <p>Shell脚本、Python脚本、Ansible剧本</p>
            <span class="template-tag">开发</span>
          </div>

          <div class="template-card">
            <div class="template-icon">💬</div>
            <h3>对话流程模板</h3>
            <p>客服话术、FAQ模板、对话流程</p>
            <span class="template-tag">客服</span>
          </div>
        </div>
      </section>

      <!-- 使用场景 -->
      <section class="scenario-section">
        <h2>🎯 使用场景</h2>
        
        <div class="scenario-list">
          <div class="scenario-item">
            <h3>🏢 企业办公</h3>
            <ul>
              <li>周报/月报自动生成</li>
              <li>会议纪要自动整理</li>
              <li>审批流程自动化</li>
            </ul>
          </div>

          <div class="scenario-item">
            <h3>🛒 电商运营</h3>
            <ul>
              <li>商品信息自动更新</li>
              <li>订单自动处理</li>
              <li>客服自动回复</li>
            </ul>
          </div>

          <div class="scenario-item">
            <h3>📱 内容运营</h3>
            <ul>
              <li>多平台内容一键分发</li>
              <li>数据自动采集分析</li>
              <li>粉丝互动自动化</li>
            </ul>
          </div>

          <div class="scenario-item">
            <h3>💻 技术开发</h3>
            <ul>
              <li>代码自动审查</li>
              <li>测试自动执行</li>
              <li>部署自动流水线</li>
            </ul>
          </div>
        </div>
      </section>

    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 20px;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
  }

  .hero h1 {
    color: #d4af37;
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .content {
    background: #fafafa;
    min-height: 60vh;
  }

  h2 {
    color: #1a1a2e;
    font-size: 1.5rem;
    margin-bottom: 25px;
    padding-bottom: 10px;
    border-bottom: 2px solid #d4af37;
  }

  .tool-card {
    background: #fff;
    border-radius: 12px;
    padding: 25px;
    margin-bottom: 20px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  }

  .tool-card h3 {
    color: #1a1a2e;
    font-size: 1.2rem;
    margin-bottom: 10px;
  }

  .tool-card p {
    color: #666;
    margin-bottom: 15px;
  }

  .tool-card ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tool-card li {
    background: #f0f0f0;
    padding: 8px 15px;
    border-radius: 20px;
    font-size: 0.85rem;
    color: #333;
  }

  .template-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .template-card {
    background: #fff;
    border-radius: 12px;
    padding: 25px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: all 0.3s;
  }

  .template-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
  }

  .template-icon {
    font-size: 2.5rem;
    margin-bottom: 15px;
  }

  .template-card h3 {
    color: #1a1a2e;
    font-size: 1.1rem;
    margin-bottom: 10px;
  }

  .template-card p {
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 15px;
  }

  .template-tag {
    display: inline-block;
    background: #e0e0e0;
    padding: 5px 15px;
    border-radius: 15px;
    font-size: 0.8rem;
    color: #666;
  }

  .scenario-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .scenario-item {
    background: #fff;
    border-radius: 12px;
    padding: 25px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  }

  .scenario-item h3 {
    color: #1a1a2e;
    font-size: 1.1rem;
    margin-bottom: 15px;
  }

  .scenario-item ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .scenario-item li {
    color: #666;
    padding: 8px 0;
    border-bottom: 1px solid #eee;
  }

  .scenario-item li:last-child {
    border-bottom: none;
  }
</style>
