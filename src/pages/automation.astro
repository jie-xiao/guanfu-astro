---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="自动化模板 - 观复阁" description="观复阁自动化模板 - 工作流模板、效率工具、自动化方案">
  <section class="hero">
    <div class="container">
      <h1>📢 自动化模板</h1>
      <p>工作流模板 · 效率工具 · 自动化方案</p>
    </div>
  </section>

  <section class="content">
    <div class="container">
      
      <section class="intro-section">
        <h2>什么是自动化模板？</h2>
        <p>自动化模板是预定义的工作流程，帮助您自动完成重复性任务，提升工作效率。</p>
      </section>

      <!-- 浏览器自动化 -->
      <section class="tool-section">
        <h2>🖥️ 浏览器自动化</h2>
        
        <div class="template-table">
          <table>
            <thead>
              <tr>
                <th>模板名称</th>
                <th>功能描述</th>
                <th>适用场景</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>自动登录脚本</td>
                <td>自动登录网站，保存凭证</td>
                <td>定时签到、批量操作</td>
              </tr>
              <tr>
                <td>数据抓取模板</td>
                <td>批量抓取网页数据</td>
                <td>市场调研、竞品监控</td>
              </tr>
              <tr>
                <td>表单自动提交</td>
                <td>批量提交表单</td>
                <td>信息录入、问卷调查</td>
              </tr>
              <tr>
                <td>定时刷新任务</td>
                <td>定时刷新页面</td>
                <td>蹲守抢购、实时监控</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- 桌面自动化 -->
      <section class="tool-section">
        <h2>🖱️ 桌面自动化</h2>
        
        <div class="template-table">
          <table>
            <thead>
              <tr>
                <th>模板名称</th>
                <th>功能描述</th>
                <th>适用场景</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>批量文件处理</td>
                <td>批量重命名、移动、压缩</td>
                <td>整理资料、数据备份</td>
              </tr>
              <tr>
                <td>截图自动化</td>
                <td>定时截图 + OCR识别</td>
                <td>验证码识别、内容提取</td>
              </tr>
              <tr>
                <td>快捷键脚本</td>
                <td>自定义快捷键</td>
                <td>提升效率、快捷操作</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- 工作流自动化 -->
      <section class="tool-section">
        <h2>🔄 工作流自动化</h2>
        
        <div class="template-table">
          <table>
            <thead>
              <tr>
                <th>模板名称</th>
                <th>功能描述</th>
                <th>适用场景</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>定时提醒</td>
                <td>定时发送通知</td>
                <td>任务提醒、截止提醒</td>
              </tr>
              <tr>
                <td>数据同步</td>
                <td>多平台数据同步</td>
                <td>跨平台同步、数据一致</td>
              </tr>
              <tr>
                <td>报告自动生成</td>
                <td>自动汇总数据生成报告</td>
                <td>日报周报、运营报告</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- 技术栈 -->
      <section class="tech-section">
        <h2>🛠️ 技术栈</h2>
        
        <div class="tech-grid">
          <div class="tech-card">
            <h3>🖥️ 浏览器自动化</h3>
            <p>Playwright, Selenium, Puppeteer</p>
          </div>
          <div class="tech-card">
            <h3>🖱️ 桌面自动化</h3>
            <p>PyAutoGUI, AutoIt, AHK</p>
          </div>
          <div class="tech-card">
            <h3>⚙️ 工作流</h3>
            <p>GitHub Actions, n8n, Zapier</p>
          </div>
        </div>
      </section>

      <!-- 使用说明 -->
      <section class="usage-section">
        <h2>📖 使用说明</h2>
        
        <ol class="steps">
          <li>选择需要的模板</li>
          <li>按照说明配置参数</li>
          <li>运行自动化脚本</li>
        </ol>
      </section>

    </div>
  </section>
</ BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 20px;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
  }

  .hero h1 {
    color: #d4af37;
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .content {
    background: #fafafa;
    min-height: 60vh;
  }

  h2 {
    color: #1a1a2e;
    font-size: 1.5rem;
    margin: 40px 0 25px;
    padding-bottom: 10px;
    border-bottom: 2px solid #d4af37;
  }

  .intro-section {
    background: #fff;
    padding: 30px;
    border-radius: 12px;
    margin-bottom: 30px;
  }

  .intro-section h2 {
    margin-top: 0;
    border-bottom: none;
  }

  .intro-section p {
    color: #666;
    line-height: 1.8;
  }

  .template-table {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    margin-bottom: 30px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th, td {
    padding: 15px 20px;
    text-align: left;
    border-bottom: 1px solid #eee;
  }

  th {
    background: #f5f5f5;
    color: #1a1a2e;
    font-weight: 600;
  }

  td {
    color: #333;
  }

  tr:last-child td {
    border-bottom: none;
  }

  tr:hover {
    background: #fafafa;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .tech-card {
    background: #fff;
    border-radius: 12px;
    padding: 25px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  }

  .tech-card h3 {
    color: #1a1a2e;
    font-size: 1.1rem;
    margin-bottom: 10px;
  }

  .tech-card p {
    color: #666;
    margin: 0;
  }

  .steps {
    background: #fff;
    padding: 30px 30px 30px 50px;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  }

  .steps li {
    color: #333;
    line-height: 2;
    font-size: 1.1rem;
  }

  .steps li::marker {
    color: #d4af37;
    font-weight: bold;
  }
</style>
