              <td><a href="https://github.com/vanhauser-thc/thc-hydra" target="_blank">访问</a></td>
            </tr>
          </tbody>
        </table>
      </section>

      <!-- 网络分析 -->
      <section class="tools-section">
        <h2>📡 网络分析</h2>
        <table class="tool-table">
          <thead>
            <tr>
              <th>工具</th>
              <th>类型</th>
              <th>推荐</th>
              <th>描述</th>
