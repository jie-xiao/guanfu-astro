              <td><a href="https://ghidra-sre.org" target="_blank">访问</a></td>
            </tr>
            <tr>
              <td>IDA Pro</td>
              <td>💰</td>
              <td>⭐⭐⭐⭐⭐</td>
              <td>商业反汇编器</td>
              <td><a href="https://www.hex-rays.com" target="_blank">访问</a></td>
            </tr>
            <tr>
              <td>Radare2</td>
              <td>🆓</td>
              <td>⭐⭐⭐⭐</td>
