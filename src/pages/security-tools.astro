          <thead>
            <tr>
              <th>工具</th>
              <th>类型</th>
              <th>推荐</th>
              <th>描述</th>
              <th>适用场景</th>
              <th>链接</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Hashcat</td>
              <td>🆓</td>
              <td>⭐⭐⭐⭐⭐</td>
