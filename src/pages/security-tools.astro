              </tr>
            </tbody>
          </table>
        </div>

        <div class="tool-category">
          <h3>漏洞扫描</h3>
          <table class="tool-table">
            <thead>
              <tr>
                <th>工具</th>
                <th>类型</th>
                <th>推荐</th>
                <th>描述</th>
                <th>链接</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Nessus</td>
                <td>💰</td>
                <td>⭐⭐⭐⭐⭐</td>
                <td>商业漏洞扫描神器</td>
