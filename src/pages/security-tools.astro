      <!-- 使用建议 -->
      <section class="suggestion-section">
        <h2>📖 使用建议</h2>
        
        <div class="suggestion-card">
          <h3>新手入门推荐</h3>
          <ol>
            <li><strong>Nmap</strong> - 网络扫描入门</li>
            <li><strong>Burp Suite</strong> - Web安全入门</li>
            <li><strong>Metasploit</strong> - 渗透框架学习</li>
            <li><strong>Wireshark</strong> - 流量分析基础</li>
          </ol>
        </div>

        <div class="suggestion-card">
          <h3>红队常用组合</h3>
          <ul>
            <li>信息收集：Nmap + Maltego + Shodan</li>
            <li>漏洞扫描：Nessus + OpenVAS</li>
            <li>渗透测试：Metasploit + Cobalt Strike</li>
          </ul>
        </div>

        <div class="suggestion-card">
          <h3>蓝队常用组合</h3>
          <ul>
            <li>网络监控：Suricata + Snort</li>
            <li>日志分析：OSSEC + Wazuh</li>
            <li>取证分析：Autopsy + Velociraptor</li>
          </ul>
        </div>
      </section>

    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 20px;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
  }

  .hero h1 {
    color: #e74c3c;
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
  }

  .legend {
    margin-top: 15px;
    font-size: 0.9rem;
    color: #f39c12;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .content {
    padding: 40px 0;
  }

  .tools-section {
    margin-bottom: 50px;
  }

  h2 {
    color: #1a1a2e;
    font-size: 1.8rem;
    margin-bottom: 25px;
    padding-bottom: 10px;
    border-bottom: 3px solid #e74c3c;
  }

  .tool-category {
    margin-bottom: 30px;
  }

  .tool-category h3 {
    color: #333;
    font-size: 1.3rem;
    margin-bottom: 15px;
  }

  .tool-table {
    width: 100%;
    border-collapse: collapse;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  }

  .tool-table th, .tool-table td {
    padding: 12px 10px;
    text-align: center;
    border-bottom: 1px solid #eee;
    font-size: 0.9rem;
  }

  .tool-table th {
    background: #e74c3c;
    color: #fff;
    font-weight: 600;
  }

  .tool-table td:first-child {
    font-weight: 600;
    color: #1a1a2e;
  }

  .tool-table tr:hover {
    background: #f9f9f9;
  }

  .tool-table a {
    color: #e74c3c;
    text-decoration: none;
    padding: 4px 10px;
    border: 1px solid #e74c3c;
    border-radius: 4px;
    font-size: 0.8rem;
  }

  .tool-table a:hover {
    background: #e74c3c;
    color: #fff;
  }

  .suggestion-section {
    margin-bottom: 50px;
  }

  .suggestion-card {
    background: #fff;
    border-radius: 12px;
    padding: 25px;
    margin-bottom: 20px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    border-left: 4px solid #e74c3c;
  }

  .suggestion-card h3 {
    color: #e74c3c;
    font-size: 1.2rem;
    margin-bottom: 15px;
  }

  .suggestion-card ol, .suggestion-card ul {
    margin: 0;
    padding-left: 20px;
  }

  .suggestion-card li {
    padding: 8px 0;
    color: #333;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .tool-table {
      font-size: 0.8rem;
    }
    
    .tool-table th, .tool-table td {
      padding: 8px 5px;
    }
  }
</style>
