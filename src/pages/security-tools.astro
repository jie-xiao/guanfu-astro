---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="安全工具导航 - 观复阁" description="观复阁安全工具导航 - 为安全从业者精选工具">
  <section class="hero">
    <div class="container">
      <h1>🛡️ 安全工具导航</h1>
      <p>为安全从业者精选工具</p>
      <p class="legend">🆓免费 | 💰付费 | 🔄freemium</p>
