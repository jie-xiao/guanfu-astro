      <!-- 防御工具 -->
      <section class="tools-section">
        <h2>🛡️ 防御工具</h2>
        <table class="tool-table">
          <thead>
            <tr>
              <th>工具</th>
              <th>类型</th>
              <th>推荐</th>
              <th>描述</th>
              <th>适用场景</th>
              <th>链接</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Suricata</td>
              <td>🆓</td>
              <td>⭐⭐⭐⭐⭐</td>
              <td>入侵检测引擎</td>
              <td>实时监控</td>
              <td><a href="https://suricata.io" target="_blank">访问</a></td>
            </tr>
            <tr>
              <td>Snort</td>
              <td>🆓</td>
              <td>⭐⭐⭐⭐</td>
              <td>入侵检测系统</td>
              <td>网络监控</td>
              <td><a href="https://www.snort.org" target="_blank">访问</a></td>
            </tr>
            <tr>
              <td>Wazuh</td>
              <td>🆓</td>
              <td>⭐⭐⭐⭐⭐</td>
