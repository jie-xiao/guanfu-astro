          </table>
        </div>

        <div class="tool-category">
          <h3>渗透框架</h3>
          <table class="tool-table">
            <thead>
              <tr>
                <th>工具</th>
                <th>类型</th>
                <th>推荐</th>
                <th>描述</th>
                <th>链接</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Metasploit</td>
                <td>🆓</td>
                <td>⭐⭐⭐⭐⭐</td>
